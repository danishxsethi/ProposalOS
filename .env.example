# Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/proposalus"

# API Keys (Required)
API_KEY="your-secret-api-key-here"

# Google Cloud
GCP_PROJECT_ID="your-gcp-project"
GCP_REGION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# Google APIs
GOOGLE_PAGESPEED_API_KEY="your-pagespeed-key"
GOOGLE_PLACES_API_KEY="your-places-key"

# SerpAPI
SERP_API_KEY="your-serpapi-key"

# LangSmith (Tracing)
LANGCHAIN_API_KEY="your-langsmith-key"
LANGCHAIN_PROJECT="proposalus-production"
LANGCHAIN_TRACING_V2=true

# Email (Resend)
RESEND_API_KEY="re_your_key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Webhooks (Optional)
WEBHOOK_URL="https://your-webhook-endpoint.com"
WEBHOOK_SECRET="optional-webhook-secret"

# Branding (Optional)
BRAND_NAME="ProposalOS"
BRAND_LOGO_URL="https://your-logo.png"
BRAND_PRIMARY_COLOR="#8B5CF6"
BRAND_ACCENT_COLOR="#38BDF8"
BRAND_CONTACT_EMAIL="contact@yourdomain.com"
BRAND_CONTACT_PHONE="+1-555-0100"
BRAND_WEBSITE="https://yourdomain.com"
BRAND_TAGLINE="Automated Local Business Audits"

# Redis (Optional, for caching)
REDIS_URL="redis://localhost:6379"

# GCS (Optional, for PDF storage)
GCS_BUCKET_NAME="proposalus-pdfs"

# Base URL
BASE_URL="http://localhost:3000"

# Admin Secret (for cache clearing, etc.)
ADMIN_SECRET="your-admin-secret"

# Cost Management
AUDIT_COST_THRESHOLD_CENTS=50  # Budget alert threshold (50 cents)

# Node Environment
NODE_ENV="development"
LOG_LEVEL="info"

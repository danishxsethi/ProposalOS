# ============================================
# ProposalOS — Production Environment Variables
# ============================================
# Copy this file and fill in values. Use as reference when configuring
# Cloud Run secrets and environment variables.
#
# CLOUD RUN SETUP:
# 1. Create secrets in Secret Manager:
#    gcloud secrets create DATABASE_URL --data-file=-
#    gcloud secrets create API_KEY --data-file=-
#    (repeat for each secret below)
#
# 2. Grant Cloud Run access:
#    gcloud secrets add-iam-policy-binding DATABASE_URL \
#      --member="serviceAccount:PROJECT_NUMBER-compute@developer.gserviceaccount.com" \
#      --role="roles/secretmanager.secretAccessor"
#
# 3. Deploy with secrets:
#    gcloud run deploy proposal-engine \
#      --set-secrets="DATABASE_URL=DATABASE_URL:latest,API_KEY=API_KEY:latest,..." \
#      --set-env-vars="GCP_PROJECT_ID=myproject,GCP_REGION=us-central1,..."
#
# ============================================

# --- REQUIRED (validated at startup) ---

# PostgreSQL connection string (Cloud SQL recommended)
DATABASE_URL="postgresql://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE"

# API key for programmatic access; Bearer token must match
API_KEY=""

# Google PageSpeed Insights API
GOOGLE_PAGESPEED_API_KEY=""

# Google Places API (Maps, GBP)
GOOGLE_PLACES_API_KEY=""

# SerpAPI for competitor/local search
SERP_API_KEY=""

# Sprint 2 enrichment waterfall providers
APOLLO_API_KEY=""
HUNTER_API_KEY=""
PROXYCURL_API_KEY=""
CLEARBIT_API_KEY=""
ZEROBOUNCE_API_KEY=""
NEVERBOUNCE_API_KEY=""

# GCP project ID (for Vertex AI, GCS, etc.)
GCP_PROJECT_ID=""

# Gemini AI via @google/generative-ai (competitor, diagnosis, proposals)
GOOGLE_AI_API_KEY=""

# --- OPTIONAL (recommended for production) ---

# Resend.com API key — enables proposal emails, follow-ups, notifications
RESEND_API_KEY=""
OUTREACH_SENDING_EMAILS="audit@domain1.com,audit@domain2.com,audit@domain3.com"
OUTREACH_SENDING_DOMAINS=""
OUTREACH_SENDER_NAME="ProposalOS Team"
OUTREACH_DOMAIN_DAILY_LIMIT="50"
OUTREACH_CALENDAR_URL=""

# GCP region (default: us-central1)
GCP_REGION="us-central1"

# GCS bucket for PDF storage
GCS_BUCKET_NAME=""

# Redis URL for distributed cache (omit for file cache)
REDIS_URL=""

# Webhook URL for fire-and-forget events
WEBHOOK_URL=""

# Default tenant when x-tenant-id header not provided
DEFAULT_TENANT_ID=""

# LangSmith tracing
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="proposalos"

# --- AUTH & SECURITY ---

# Admin endpoint auth — x-admin-key header must match (cache clear)
ADMIN_SECRET=""

# Cron job auth — Bearer token for scheduled-audits, follow-ups, monitor-reputation
CRON_SECRET=""

# --- APP URLs (required for emails, redirects, share links) ---

# Public app URL (emails, share links)
NEXT_PUBLIC_APP_URL="https://your-app.run.app"
NEXTAUTH_URL="https://your-app.run.app"

# Server-side base URL (PDF generation, internal redirects)
BASE_URL="https://your-app.run.app"

# Client-side base URL (proposal share links)
NEXT_PUBLIC_BASE_URL="https://your-app.run.app"

# --- OAUTH (optional — NextAuth Google provider) ---
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- STRIPE (optional — billing) ---
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRICE_ID_STARTER=""
# STRIPE_PRICE_ID_PRO=""
# STRIPE_PRICE_ID_AGENCY=""

# --- BRANDING ---
# BRAND_NAME="ProposalOS"
# BRAND_LOGO_URL=""
# BRAND_PRIMARY_COLOR="#6366f1"
# BRAND_ACCENT_COLOR="#38BDF8"
# BRAND_CONTACT_EMAIL=""
# BRAND_TAGLINE=""
# BRAND_FOOTER_TEXT=""

# --- MISC ---
# OPERATOR_EMAIL=""              # Internal notification recipient
# AUDIT_COST_THRESHOLD_CENTS="50"
# CLUSTERING_MODEL="gemini-2.0-flash"
# LOG_LEVEL="info"
# CHROME_EXECUTABLE_PATH=""      # For PDF generation (Cloud Run: use built-in)
# GOOGLE_APPLICATION_CREDENTIALS=""  # Service account JSON path (Vertex AI)
